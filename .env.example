# Brave Search API (for --news feature)
# Get your free key at: https://api.search.brave.com
# Free tier: 2,000 requests/month
BRAVE_API_KEY=your_brave_search_api_key_here

# Telegram stock debate bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional: comma-separated private chat IDs allowed to use the bot
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
# Optional: override the default stock template
# TELEGRAM_DEFAULT_TEMPLATE_ID=news-stock-bull-bear-risk
# Optional: pin the Ollama-compatible providers used by the Telegram bot
# Default order when unset:
# ollama-cloud-qwen3-5-397b, ollama-cloud-glm-5, ollama-cloud-nemotron-3-super,
# ollama-cloud-kimi-k2-5, ollama-cloud-minimax-m2-5
# TELEGRAM_OLLAMA_PROVIDER_IDS=ollama-cloud-qwen3-5-397b,ollama-cloud-glm-5,ollama-cloud-nemotron-3-super,ollama-cloud-kimi-k2-5,ollama-cloud-minimax-m2-5
