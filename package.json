{
  "name": "fight-for-me",
  "version": "0.3.0",
  "description": "AI Debate CLI - Codex vs Claude multi-round debates via local CLIs",
  "type": "module",
  "bin": {
    "fight-for-me": "./dist/cli.js",
    "ffm": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "debate",
    "codex",
    "claude",
    "cli",
    "openai",
    "anthropic"
  ],
  "author": "GiSung Lee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Leekee0905/fight-for-me.git"
  },
  "homepage": "https://github.com/Leekee0905/fight-for-me#readme",
  "bugs": {
    "url": "https://github.com/Leekee0905/fight-for-me/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@inquirer/prompts": "^7.2.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "openai": "^4.73.0",
    "ora": "^8.1.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
