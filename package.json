{
  "name": "fight-for-me",
  "version": "0.1.0",
  "description": "AI Debate CLI - Codex vs Claude multi-round debates via local CLIs",
  "type": "module",
  "bin": {
    "fight-for-me": "./dist/cli.js",
    "ffm": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "debate", "codex", "claude", "cli", "openai", "anthropic"],
  "author": "GiSung Lee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Leekee0905/fight-for-me.git"
  },
  "homepage": "https://github.com/Leekee0905/fight-for-me#readme",
  "bugs": {
    "url": "https://github.com/Leekee0905/fight-for-me/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "@anthropic-ai/sdk": "^0.32.0",
    "commander": "^12.1.0",
    "@inquirer/prompts": "^7.2.0",
    "chalk": "^5.3.0",
    "boxen": "^8.0.1",
    "ora": "^8.1.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
