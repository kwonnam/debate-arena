{
  "name": "debate-arena",
  "version": "0.5.2",
  "description": "AI Debate CLI - Codex vs Claude multi-round debates via local CLIs",
  "type": "module",
  "bin": {
    "debate-arena": "./dist/bin/cli.js",
    "da": "./dist/bin/cli.js",
    "ffm": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "dashboard"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/bin/cli.js",
    "package:local": "npm run build && mkdir -p .release && npm pack --pack-destination .release",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "debate",
    "codex",
    "claude",
    "cli",
    "openai",
    "anthropic"
  ],
  "author": "kwonnam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kwonnam/debate-arena.git"
  },
  "homepage": "https://github.com/kwonnam/debate-arena#readme",
  "bugs": {
    "url": "https://github.com/kwonnam/debate-arena/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@inquirer/prompts": "^7.2.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "hono": "^4.6.0",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
